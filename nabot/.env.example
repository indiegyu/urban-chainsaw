# ---------- Naver Search API ----------
# https://developers.naver.com → 검색 API 앱 등록 후 발급
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ---------- Twitter / X ----------
# https://developer.twitter.com → Bearer Token
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ---------- Google Alerts RSS ----------
# google.com/alerts → 키워드 설정 → RSS 링크 복사
# 형식: "키워드1=RSS_URL1,키워드2=RSS_URL2"
GOOGLE_ALERTS_RSS_URLS=소음발광=https://www.google.com/alerts/feeds/...,솜발=https://...

# ---------- 카카오 ----------
# 카카오 개발자센터 → 내 앱 → Admin 키
KAKAO_ADMIN_KEY=your_kakao_admin_key

# 알림 발송 모드: "api" (실제 발송) | "log" (콘솔 출력만, 테스트용)
KAKAO_NOTIFY_MODE=log

# ---------- 보안 ----------
# 내부 API 보호용 시크릿 (아무 문자열 사용)
INTERNAL_SECRET=change-me-to-a-random-string
