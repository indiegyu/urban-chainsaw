# ---------- Naver Search API ----------
# https://developers.naver.com → 검색 API 앱 등록 후 발급
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ---------- Twitter / X ----------
# https://developer.twitter.com → Bearer Token
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ---------- Google Custom Search API ----------
# https://programmablesearchengine.google.com → 검색 엔진 생성 (전체 웹 검색 활성화)
# https://console.cloud.google.com → Custom Search JSON API 활성화 → API 키 발급
# 무료: 100 queries/day (초과 시 $5/1,000 queries)
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_ID=your_search_engine_id

# ---------- 카카오 ----------
# 카카오 개발자센터 → 내 앱 → Admin 키
KAKAO_ADMIN_KEY=your_kakao_admin_key

# 알림 발송 모드: "api" (실제 발송) | "log" (콘솔 출력만, 테스트용)
KAKAO_NOTIFY_MODE=log

# ---------- 카카오 i 오픈빌더 블록 ID ----------
# 오픈빌더 > 각 블록 > 우측 상단 "블록 ID 복사" 로 확인
BLOCK_MAIN=xxxxxxxxxxxxxxxxxxxxxxxx
BLOCK_ADD_KEYWORD=xxxxxxxxxxxxxxxxxxxxxxxx
BLOCK_LIST_KEYWORDS=xxxxxxxxxxxxxxxxxxxxxxxx
BLOCK_SEARCH_NOW=xxxxxxxxxxxxxxxxxxxxxxxx
BLOCK_UPGRADE=xxxxxxxxxxxxxxxxxxxxxxxx

# ---------- 보안 ----------
# 내부 API 보호용 시크릿 (아무 문자열 사용)
INTERNAL_SECRET=change-me-to-a-random-string
