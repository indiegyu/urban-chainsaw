# ╔══════════════════════════════════════════════════════════════╗
# ║  Urban-Chainsaw  –  환경변수 템플릿                            ║
# ║  이 파일을 .env 로 복사한 뒤 값을 채우세요                        ║
# ║  $ cp .env.example .env                                       ║
# ╚══════════════════════════════════════════════════════════════╝

# ── AI 텍스트 생성 ──────────────────────────────────────────────
# Groq: https://console.groq.com  (무료 티어 제공)
GROQ_API_KEY=gsk_...

# ── AI 이미지 생성 ──────────────────────────────────────────────
# Ideogram: https://ideogram.ai  (무료 티어: 25 이미지/일)
IDEOGRAM_API_KEY=...

# ── 음성 합성 ───────────────────────────────────────────────────
# ElevenLabs: https://elevenlabs.io  (무료 티어: 10,000 chars/월)
ELEVENLABS_API_KEY=...

# ── 스톡 영상 ───────────────────────────────────────────────────
# Pexels: https://www.pexels.com/api/  (무료, 무제한)
PEXELS_API_KEY=...

# ── Print-on-Demand ─────────────────────────────────────────────
# Printify: https://printify.com  (무료 가입)
PRINTIFY_API_KEY=...
PRINTIFY_SHOP_ID=...

# Etsy: https://www.etsy.com/developers
ETSY_API_KEY=...
ETSY_SHOP_ID=...

# ── YouTube Data API v3 ─────────────────────────────────────────
# Google Cloud Console: https://console.cloud.google.com
# YouTube Data API v3 활성화 → OAuth2 credentials.json 다운로드
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# ── SNS 자동 공유 ───────────────────────────────────────────────
# Twitter/X Developer Portal: https://developer.twitter.com
TWITTER_BEARER_TOKEN=...
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...

# ── Ghost CMS ───────────────────────────────────────────────────
# Ghost Admin → Settings → Integrations → Add custom integration
GHOST_URL=http://localhost:2368
GHOST_ADMIN_API_KEY=...  # format: id:secret

# ── Slack 알림 (선택) ───────────────────────────────────────────
SLACK_CHANNEL_ID=...
# Slack Bot Token (xoxb-...)
# n8n의 Slack credential로 설정

# ── n8n 설정 ────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=change_me_to_random_32char_string
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/

# ── PostgreSQL (n8n용) ──────────────────────────────────────────
POSTGRES_USER=urban
POSTGRES_PASSWORD=change_me_strong_password

# ── Ghost MySQL ─────────────────────────────────────────────────
GHOST_DB_PASSWORD=change_me_ghost_password
GHOST_DB_ROOT_PASSWORD=change_me_root_password

# ── Gmail SMTP (Ghost 이메일 발송, 선택) ────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=...  # Google App Password (2FA 필수)

# ── Micro-SaaS (Phase 4) ────────────────────────────────────────
# Supabase: https://supabase.com  (무료 티어)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe: https://stripe.com  (판매 시 수수료만, 월정액 없음)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...       # Pro $29/월 Stripe Price ID
STRIPE_PRICE_BUSINESS=price_...  # Business $99/월 Stripe Price ID

# ── Multi-Platform Publishing ────────────────────────────────────
# Dev.to: https://dev.to/settings/extensions → Generate API Key (무료)
DEVTO_API_KEY=...

# Medium: https://medium.com/me/settings → Integration tokens (무료)
MEDIUM_TOKEN=...

# GitHub Pages AdSense (승인 후 입력)
# Google AdSense: https://www.google.com/adsense/
ADSENSE_CLIENT_ID=ca-pub-...
BLOG_CUSTOM_DOMAIN=         # 커스텀 도메인 (예: blog.yourdomain.com)
GITHUB_PAGES_URL=https://USERNAME.github.io/urban-chainsaw

# ── Podcast (Spotify / Apple Podcasts) ──────────────────────────
# Spotify 등록: https://podcasters.spotify.com/ → RSS URL 제출 (무료)
PODCAST_TITLE=AI Income Automation Daily
PODCAST_DESCRIPTION=Daily AI tips and strategies to earn more
PODCAST_AUTHOR=AI Income Bot
PODCAST_EMAIL=your@email.com

# ── Beehiiv 뉴스레터 ─────────────────────────────────────────────
# Beehiiv: https://www.beehiiv.com/ → Settings → API (무료 2500명까지)
BEEHIIV_API_KEY=...
BEEHIIV_PUB_ID=pub_...

# ── Twitter/X 자동 포스팅 ────────────────────────────────────────
# Twitter Developer Portal: https://developer.twitter.com/
# → Create App → OAuth 1.0a → Read and Write permissions
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@YOUR_CHANNEL

# ── Reddit 공유 ──────────────────────────────────────────────────
# Reddit App 등록: https://www.reddit.com/prefs/apps → script 타입
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ── YouTube 채널 관리 (full scope) ───────────────────────────────
YT_FULL_REFRESH_TOKEN=1//...  # youtube scope OAuth refresh token
